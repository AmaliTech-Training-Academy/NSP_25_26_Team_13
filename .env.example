# =============================================================
# LogStream — Environment Variables Template
# Team 13 | AmaliTech Training Academy
#
# SETUP: cp .env.example .env then fill in your values.
# WARNING: Never commit .env to version control.
#          It is listed in .gitignore.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_PORT=5432

# ── Backend (Spring Boot) ─────────────────────────────────────
JWT_SECRET=
SPRING_PROFILES_ACTIVE=dev

# ── MinIO (Object Storage) ────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# ── Metabase ──────────────────────────────────────────────────
METABASE_PORT=3000

# ── Backend API ───────────────────────────────────────────────
BACKEND_PORT=8080
